{
	"events": [
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Ele para."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "O olhar acompanha os três atravessando o salão."
		},
		{
			"character": "character-1777851120.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Então eles sabem alguma coisa."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Amara se levanta antes mesmo dele terminar."
		},
		{
			"character": "character-1777839556.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Ótimo."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Aslan ergue uma sobrancelha."
		},
		{
			"character": "character-1777851120.json",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Ótimo?"
		},
		{
			"choice": "Faz meses que a gente está ouvindo rumores.",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"choice": "Estamos nessa há meses.",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"choice": "Não é para isso que estamos aqui?",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"choice": "Já desistiu?",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Ele solta uma risada curta."
		},
		{
			"character": "character-1777839556.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Pela primeira vez temos pessoas de verdade."
		},
		{
			"character": "character-1777851120.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Pessoas que provavelmente tentaram me matar."
		},
		{
			"character": "character-1777839556.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Melhor ainda."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Ele solta outra risada. Pequena. Mas sincera."
		},
		{
			"character": "character-1777851120.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Você é assustadora."
		},
		{
			"character": "character-1777839556.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Você é lento."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Os dois deixam algumas moedas sobre a mesa. Sem pressa. Sem chamar atenção. Esperam os homens saírem primeiro."
		},
		{
			"background": "res://Artes/diario/IMG_3081.png",
			"event_id": "dialogic_021"
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "A porta da Viajante Errante se fecha atrás deles."
		},
		{
			"choice": "Ficar",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_024",
