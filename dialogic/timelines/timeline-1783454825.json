			],
			"portrait": "",
			"question": ""
		},
		{
			"choice": "Reiniciar",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"change_scene": "res://project/MainScene.tscn",
			"event_id": "dialogic_041"
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"choice": "Sair",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"emit_signal": "seguindo_suspeitos",
			"event_id": "dialogic_040"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Um minuto depois, saímos também. A distância entre os grupos é segura. Nem perto demais. Nem longe demais."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "O movimento da estalagem desaparece. O Viajante Errante fica para trás. Então surge a floresta. Imensa. Densa."
		},
		{
			"background": "res://Artes/Arte-TFEAE/floresta densa.jpg",
			"event_id": "dialogic_021"
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Os homens não diminuem o passo. Entram entre as árvores como quem já fez aquele caminho dezenas de vezes."
		},
		{
			"choice": "Parar",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Você para por um instante na borda da mata. O vento sopra, e com ele surge uma certeza. Carregando aquele mesmo sentimento estranho. Aquele mesmo chamado silencioso que os acompanha."
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Ao seu lado, Aslan observa o interior da floresta. Depois olha para ela. Nenhum dos dois precisa dizer nada."
		},
		{
			"choice": "Segui-los",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"emit_signal": "chamado_vento",
			"event_id": "dialogic_040"
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "E, sem hesitar mais, atravessam a linha das árvores. A floresta os engole."
		},
		{
			"event_id": "dialogic_013"
		}
