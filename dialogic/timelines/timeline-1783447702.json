{
	"events": [
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Primeiro distante. Depois mais próximo."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Gritos."
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "O tipo de voz que chama atenção sem querer chamar ajuda."
		},
		{
			"choice": "Inspecionar os gritos.",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Amara desvia o olhar da mesa na mesma hora. "
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Aslan ergue levemente a cabeça, atento."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Outro grito. Mais perto agora. Mas ninguém se levanta. "
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Isso parece dizer muito sobre aquela cidade."
		},
		{
			"choice": "Olhar pela janela.",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Amara inclina um pouco o corpo para olhar melhor pela janela."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Lá fora, perto da saída que leva para a área mais baixa da cidade — próxima da direção da floresta ."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Outro som seco ecoa. Algo sendo atingido."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Aslan também olha, mas evita ficar exposto demais na janela."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "E então Amara vê. Um garoto. Branco, magro, cabelo castanho muito curto, quase raspado. Os olhos castanhos estão arregalados mais de raiva do que medo. "
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Ele está caído junto à cadeira de rodas enquanto três homens o cercam."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Ele desfere um chute na cabeça do homem e, em seguida, agarra uma de suas pernas, forçando-a até que um estalo seco ecoe pelo ambiente."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Um dos outros homens ri, zombando da completa ausência de qualquer expressão de dor."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Outro já se aproxima da perna restante, impaciente, como se estivesse ansioso para repetir o mesmo procedimento."
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Amara sente o corpo tensionar."
		},
		{
			"choice": "Intervir",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"choice": "Ignorar",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Amara consegue ouvir tudo dali."
		},
		{
			"character": "character-1783100813.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Vê se morre."
		},
		{
			"character": "character-1783100811.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Você ouviu aleijado?"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Outro chute."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "O garoto tenta acertar um deles de volta, mas um dos homens segura o braço dele antes."
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Tudo indica que o próximo alvo será seu braço. Amara sente o corpo tensionar."
		},
		{
			"choice": "Intervir",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "A porta se abre forte contra o vento quando ela atravessa a entrada sem hesitar."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Lá fora, um dos homens ainda segura o braço enquanto o outro chuta o garoto de novo, dessa vez com força suficiente para apagá-lo completamente."
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "O terceiro te encara."
