{
	"events": [
		{
			"condition": "",
			"definition": "1783478362-366",
			"event_id": "dialogic_012",
			"value": "ferrou"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Um dos outros homens assovia"
		},
		{
			"character": "character-1783100811.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Temos companhia."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "O terceiro deixa o olhar passear por você sem o menor pudor."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Um sorriso preguiçoso surge em seu rosto."
		},
		{
			"character": "character-1783472721.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "E que companhia."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "O outro dá uma risada."
		},
		{
			"character": "character-1783472721.json",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Se veio se juntar à festa, acho que podemos levá-la para um lugar mais reservado."
		},
		{
			"choice": "Encarar",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Seu olhar desce até o rapaz caído no chão. Você observa a cena por alguns segundos. O silêncio faz os homens trocarem olhares."
		},
		{
			"character": "character-1783100813.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Então?"
		},
		{
			"character": "character-1777839556.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Então, seria uma pena parar agora."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Os três ficam em silêncio. Te encarando. A ponta do seu dedo se acende. Você volta a olhar para o homem desacordado."
		},
		{
			"character": "character-1777839556.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Pelo que estou vendo, vocês já começaram sem mim."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Por um instante, ninguém reage."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Então uma gargalhada explode entre eles."
		},
		{
			"character": "character-1783100813.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Eu sabia! "
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Um deles aponta para você."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "O terceiro abre um sorriso satisfeito."
		},
		{
			"character": "character-1783472721.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Gostei dela."
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Você se abaixa."
		},
		{
			"choice": "Queimar.",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "A chama na ponta de seus dedos começa a queimar o corpo do homem. Ela aumenta."
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Ele grita. Se contorce. Pede socorro."
		},
		{
			"choice": "Queimar o olho dele.",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_010",
			"options": [

			],
			"portrait": "",
			"question": "Não há sangue. Apenas a pele carbonizada cobrindo metade do rosto."
		},
		{
			"choice": "Queimar a Língua.",
			"condition": "",
			"definition": "",
			"event_id": "dialogic_011",
			"value": ""
		},
		{
			"event_id": "dialogic_013"
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Não há mais nenhum som a ser emitido, mas o sofrimento é nítido. Ele se contorce enquanto seu corpo é consumido pelas chamas. Observando tudo, fascinada pelo sofrimento que causa."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Até os três homens parecem abalados. O entusiasmo de antes desaparece, deixando apenas surpresa e receio. Com um passo trêmulo, um deles se aproxima."
		},
		{
			"character": "character-1783100811.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Sabia que tinha algo diferente em você."
		},
		{
			"character": "",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "O olhar dele desce por você mais uma vez."
		},
		{
			"character": "character-1783100811.json",
			"event_id": "dialogic_001",
			"portrait": "",
			"text": "Talvez a gente se dê bem, afinal."
		},
